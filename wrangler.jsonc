{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "blog",
	"compatibility_date": "2025-03-01",
	"assets": {
		"directory": "./dist"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "blog.zaki-yama.dev",
			"custom_domain": true
		}
	],
	"vars": {
		"PUBLIC_SITE_URL": "https://blog.zaki-yama.dev",
		"PUBLIC_GA_ID": "G-WTRHNJ8JBX"
	}
}
