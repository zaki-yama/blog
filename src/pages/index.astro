---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG, getBaseUrl } from '../lib/site-config';
import { generateWebSiteJsonLd, generateOrganizationJsonLd } from '../lib/structured-data';

const posts = await getCollection('posts');
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const baseUrl = getBaseUrl();
const websiteJsonLd = generateWebSiteJsonLd({
  name: SITE_CONFIG.name,
  description: SITE_CONFIG.description,
  url: baseUrl,
  author: SITE_CONFIG.author.name,
});
const organizationJsonLd = generateOrganizationJsonLd(baseUrl);
---

<BaseLayout title={SITE_CONFIG.name} description={SITE_CONFIG.description}>
  <script type="application/ld+json" set:html={websiteJsonLd} />
  <script type="application/ld+json" set:html={organizationJsonLd} />

  <div class="mx-auto px-8 py-12 max-w-[896px]">
    <header class="mb-12">
      <div class="flex items-center gap-5">
        <img src="/logo.png" alt={SITE_CONFIG.name} class="w-24 h-24 rounded-full" />
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">
            {SITE_CONFIG.name}
          </h1>
        </div>
      </div>
    </header>

    <section>
      <div class="space-y-0">
        {
          sortedPosts.map(({ id, data: { date, title, category } }, index) => (
            <a href={`/posts/${id}`} class="group block">
              <article
                class={`grid grid-cols-[100px_1fr] gap-6 py-4 ${index !== 0 ? 'border-t border-gray-100 dark:border-gray-800' : ''}`}
              >
                <div class="text-sm text-gray-400 dark:text-gray-500 pt-0.5 font-mono">{date}</div>
                <div>
                  <h2 class="text-base font-medium text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-relaxed">
                    {title}
                  </h2>
                  <span class="text-xs text-gray-400 dark:text-gray-500 mt-1 inline-block">
                    {category}
                  </span>
                </div>
              </article>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
